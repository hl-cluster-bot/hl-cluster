{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  packageRules: [
    {
      description: "Handle TorrServer MatriX image tags",
      matchDatasources: ["docker"],
      matchPackageNames: ["ghcr.io/yourok/torrserver"],
      versioning: "regex:^MatriX\\.(?<major>\\d+)$",
    },
  ],
}
