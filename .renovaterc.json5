{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "github>tolkonepiu/hl-cluster//.renovate/customManagers.json5",
    "github>tolkonepiu/hl-cluster//.renovate/grafanaDashboards.json5",
    "github>tolkonepiu/hl-cluster//.renovate/groups.json5",
    "github>tolkonepiu/hl-cluster//.renovate/labels.json5",
    "github>tolkonepiu/hl-cluster//.renovate/semanticCommits.json5",
    "github>tolkonepiu/hl-cluster//.renovate/customVersioning.json5",
    ":dependencyDashboard",
    ":disableRateLimiting",
    ":semanticCommits",
  ],
  dependencyDashboard: false,
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  ignorePaths: ["**/*.sops.*"],
  flux: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  "helm-values": {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  helmfile: {
    managerFilePatterns: ["/(^|/)helmfile\\.ya?ml(?:\\.j2)?$/"],
  },
  kubernetes: {
    managerFilePatterns: ["/(^|/)kubernetes/.+\\.ya?ml(?:\\.j2)?$/"],
  },
  kustomize: {
    managerFilePatterns: ["/^kustomization\\.ya?ml(?:\\.j2)?$/"],
  },
  packageRules: [
    {
      matchUpdateTypes: ["minor", "patch", "pin", "digest"],
      automerge: true,
    },
  ],
}
