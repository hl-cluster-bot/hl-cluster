{
  "gateway": {
    "host": "0.0.0.0",
    "port": 18790,
    "token": "env:GOCLAW_GATEWAY_TOKEN"
  },
  "providers": {
    "openai": {
      "api_key": "env:GOCLAW_OPENAI_API_KEY"
    },
    "openrouter": {
      "api_key": "env:GOCLAW_OPENROUTER_API_KEY"
    }
  },
  "tools": {
    "profile": "full",
    "mcp_servers": {
      "filesystem": {
        "transport": "stdio",
        "command": "npx",
        "args": [
          "-y",
          "@modelcontextprotocol/server-filesystem",
          "$GOCLAW_WORKSPACE"
        ],
        "tool_prefix": "filesystem_",
        "timeout_sec": 60
      },
      "github-mcp-server": {
        "transport": "streamable-http",
        "url": "https://api.githubcopilot.com/mcp/",
        "headers": { "Authorization": "env:GITHUB_BEARER_TOKEN" },
        "tool_prefix": "github_mcp_server_",
        "timeout_sec": 30
      },
      "context7": {
        "transport": "streamable-http",
        "url": "https://mcp.context7.com/mcp",
        "headers": { "CONTEXT7_API_KEY": "env:CONTEXT7_API_KEY" },
        "tool_prefix": "context7_",
        "timeout_sec": 30
      },
      "kubernetes-mcp": {
        "transport": "sse",
        "url": "http://kubernetes-mcp-server.automation.svc.cluster.local:8080/sse",
        "tool_prefix": "kubernetes_mcp_",
        "timeout_sec": 30
      },
      "victoria-metrics-mcp": {
        "transport": "sse",
        "url": "http://victoriametrics-mcp-server.automation.svc.cluster.local:8080/sse",
        "tool_prefix": "victoria_metrics_mcp_",
        "timeout_sec": 30
      },
      "flux-mcp": {
        "transport": "sse",
        "url": "http://flux-operator-mcp.automation.svc.cluster.local:9090/sse",
        "tool_prefix": "flux_mcp_",
        "timeout_sec": 30
      }
    }
  }
}
