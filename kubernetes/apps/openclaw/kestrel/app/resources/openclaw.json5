{
  gateway: {
    reload: {
      mode: "off",
    },
  },
  agents: {
    defaults: {
      memorySearch: {
        enabled: false,
      },
    },
  },
  plugins: {
    // Temporarily disable the memory slot until operator plugin installation
    // lands the mem0 package in an OpenClaw-discoverable extensions path.
    // slots: {
    //   memory: "openclaw-mem0",
    // },
    entries: {
      "openclaw-mem0": {
        enabled: true,
        config: {
          mode: "open-source",
          userId: "default",
          oss: {
            vectorStore: {
              provider: "pgvector",
              config: {
                connection_string: "postgresql://${OPENCLAW_MEM0_DB_USER}:${OPENCLAW_MEM0_DB_PASS}@tolstoy-rw.database.svc.cluster.local:5432/${OPENCLAW_MEM0_DBNAME}",
                sslmode: "disable",
              },
            },
          },
        },
      },
    },
  },
}
